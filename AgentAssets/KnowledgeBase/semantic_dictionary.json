{
  "schema_version": "2.0",
  "description": "Human-readable semantic mapping asset for vendor header interpretation, defaults, and adaptive reuse across vendor formats.",
  "governance": {
    "user_review_precedes_ai_when_practical": true,
    "cross_vendor_reuse_precedes_ai_for_new_vendors": true,
    "rule_statuses": [
      "active",
      "deprecated",
      "retired",
      "replaced"
    ],
    "confidence_scale": "0.0_to_1.0",
    "notes": [
      "Use shared concepts as reusable seeds before inventing new vendor-specific rules.",
      "Deprecate or replace stale rules instead of deleting history when a vendor format changes.",
      "User-confirmed edits should outrank AI suggestions when both exist for the same match."
    ]
  },
  "cross_vendor_seed_behavior": {
    "new_vendor_review_flow": [
      "shared_concepts",
      "existing_vendor_patterns",
      "user_review",
      "ai_assist"
    ],
    "seed_mode": "propose_shared_matches_before_vendor_specific_rules_are_created",
    "require_user_review_for_seeded_matches": true,
    "allow_seed_reuse_from_existing_vendors": true,
    "notes": [
      "Shared concepts provide the first reusable interpretation pass for a new vendor.",
      "Existing vendor patterns can be reviewed as seed candidates when shared concepts are insufficient.",
      "AI should only see unresolved cases after deterministic reuse and user review paths are exhausted."
    ]
  },
